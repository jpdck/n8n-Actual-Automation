        "jsCode": "return [{\n  json: {\n    // Your Actual Budget bridge container name/URL (no trailing slash)\n    // If using Docker Compose, this is typically the service name\n    bridgeUrl: 'http://actual-bridge:3788',\n    telegramChatId:   'REPLACE_WITH_YOUR_TELEGRAM_CHAT_ID',\n  }\n}];"
      },
      "id": "e231c902-4059-4a81-8fb3-41db6520ff9c",
      "name": "Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
