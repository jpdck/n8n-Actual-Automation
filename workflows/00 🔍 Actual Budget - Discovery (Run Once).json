        "jsCode": "const catRes = $input.item.json;\nconst config = $('Config').item.json;\nreturn [{ json: { ...config, categoryGroups: catRes.data || [] } }];"
      },
      "id": "ac294bf9-c88f-436d-888a-96ff847df445",
      "name": "Store Categories",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5712,
        560
      ]
    },
    {
      "parameters": {
        "url": "={{ $json.bridgeUrl }}/accounts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "options": {},
        "authentication": "genericCredentialType",
        "genericAuthType": "httpCustomAuth"
      },
      "id": "2eaebf6e-5d66-46a5-91fe-ce3a506f0dad",
      "name": "Get Accounts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        5904,
        560
      ],
      "credentials": {
        "httpCustomAuth": {
          "id": "CRED_BRIDGE_ID",
          "name": "Actual Budget Bridge"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const accRes = $input.item.json;\nconst prev = $('Store Categories').item.json;\nconst accounts = accRes.data || [];\nconst groups = prev.categoryGroups || [];\n\n// Plain text only — avoids ALL Telegram Markdown parse errors\nlet msg = '=== ACTUAL BUDGET DISCOVERY ===\\n\\n';\n\nmsg += '--- ACCOUNTS ---\\n';\nmsg += '(copy IDs into workflow 04)\\n\\n';\nfor (const acc of accounts) {\n  if (acc.closed) continue;\n  const bal = (acc.balance || 0) / 100;\n  msg += acc.name + '\\n';\n  msg += 'ID: ' + acc.id + '\\n';\n  msg += 'Balance: $' + bal.toLocaleString('en-US', { minimumFractionDigits: 2 }) + '\\n\\n';\n}\n\nmsg += '\\n--- CATEGORY IDs ---\\n';\nmsg += '(copy into workflows 02 + 03)\\n\\n';\nfor (const group of groups) {\n  if (group.hidden) continue;\n  msg += '[' + group.name + ']\\n';\n  for (const cat of (group.categories || [])) {\n    if (cat.hidden) continue;\n    msg += '  ' + cat.name + '\\n';\n    msg += '  ' + cat.id + '\\n';\n  }\n  msg += '\\n';\n}\n\nmsg += 'Bridge: ' + prev.bridgeUrl;\n\n// Split into chunks under 3800 chars (safe under Telegram 4096 limit)\nconst LIMIT = 3800;\nconst messages = [];\nif (msg.length <= LIMIT) {\n  messages.push(msg);\n} else {\n  const lines = msg.split('\\n');\n  let chunk = '';\n  for (const line of lines) {\n    if (chunk.length + line.length + 1 > LIMIT) {\n      messages.push(chunk.trim());\n      chunk = line + '\\n';\n    } else {\n      chunk += line + '\\n';\n    }\n  }\n  if (chunk.trim()) messages.push(chunk.trim());\n}\n\nreturn messages.map((m, i) => ({\n  json: {\n    telegramChatId: $('Config').first().json.telegramChatId,\n    telegramMessage: messages.length > 1 ? '(' + (i+1) + '/' + messages.length + ')\\n\\n' + m : m\n  }\n}));"
      },
      "id": "55f2fff4-892b-4172-9970-5984a3bd3ea0",
      "name": "Format Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        6112,
        560
      ]
    },
