        "url": "={{ $json.bridgeUrl }}/health",
        "options": {}
      },
      "id": "9b34f495-1f13-44eb-9e6f-f50024c060ad",
      "name": "Health Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        5104,
        560
      ]
    },
    {
      "parameters": {
        "jsCode": "const health = $input.item.json;\nconst config = $('Config').item.json;\nif (health.status !== 'ok') throw new Error('Bridge unhealthy: ' + JSON.stringify(health));\nif (!health.initialized) throw new Error('Bridge not initialized yet — wait a few seconds and retry');\nreturn [{ json: config }];"
      },
      "id": "9bd0aa28-2fac-4ed2-84b6-e8e3ef96b122",
